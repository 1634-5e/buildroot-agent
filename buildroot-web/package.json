{
  "name": "buildroot-web",
  "version": "2.1.0",
  "description": "Buildroot Agent Web Console",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-web-links": "^0.11.0",
    "ace-builds": "^1.32.0"
  },
  "devDependencies": {
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "jsdom": "^23.0.0"
  },
  "vitest": {
    "test": {
      "environment": "jsdom",
      "globals": true,
      "coverage": {
        "reporter": ["text", "html", "json"],
        "exclude": ["node_modules/", "dist/"]
      }
    }
  }
}
