# Buildroot Agent Server - Environment Variables
# 可通过环境变量覆盖配置文件中的值
# 环境变量前缀: BR_SERVER_

# 服务器配置
BR_SERVER_HOST=0.0.0.0
BR_SERVER_WS_PORT=8765
BR_SERVER_SOCKET_PORT=8766
BR_SERVER_PING_INTERVAL=30
BR_SERVER_PING_TIMEOUT=10
BR_SERVER_SESSION_TIMEOUT=300

# 目录配置
BR_SERVER_UPLOAD_DIR=./uploads
BR_SERVER_UPDATES_DIR=./updates
BR_SERVER_LATEST_YAML=./updates/latest.yml

# 文件传输配置
BR_SERVER_MAX_RETRIES=5
BR_SERVER_RETRY_DELAY_BASE=1.0

# 数据库配置
BR_SERVER_DB_TYPE=postgresql
BR_SERVER_DB_HOST=localhost
BR_SERVER_DB_PORT=5432
BR_SERVER_DB_USER=buildroot
BR_SERVER_DB_PASSWORD=buildroot
BR_SERVER_DB_NAME=buildroot_agent
BR_SERVER_DB_POOL_MIN=5
BR_SERVER_DB_POOL_MAX=20

# 日志配置
BR_SERVER_LOG_LEVEL=INFO

# 配置文件路径（可选）
BR_SERVER_CONFIG=config.yaml
