# Buildroot Agent 开发环境配置
# 复制此文件为 .env 并根据需要修改

# ==================== PostgreSQL ====================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=buildroot
POSTGRES_PASSWORD=buildroot123
POSTGRES_DB=buildroot_agent

# PostgreSQL 连接字符串
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ==================== Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=buildroot123

# Redis 连接字符串
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# ==================== MQTT (EMQX) ====================
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_WS_PORT=8083
MQTT_TLS_PORT=8883
MQTT_DASHBOARD_PORT=18083

# MQTT 管理员
MQTT_ADMIN_USER=admin
MQTT_ADMIN_PASSWORD=buildroot123

# MQTT 连接 URL（用于 Agent）
MQTT_URL=mqtt://${MQTT_HOST}:${MQTT_PORT}

# ==================== Twin 配置 ====================
# Twin 同步间隔（秒）
TWIN_SYNC_INTERVAL=30

# 本地状态文件路径
TWIN_STATE_FILE=/var/lib/agent/twin.json

# 心跳间隔（秒）
TWIN_HEARTBEAT_INTERVAL=60

# ==================== 开发配置 ====================
# 日志级别
LOG_LEVEL=debug

# 环境
ENV=development

# ==================== 安全配置 ====================
# JWT 密钥（生产环境请更换）
JWT_SECRET=change-this-in-production

# API 密钥（生产环境请更换）
API_KEY=change-this-in-production